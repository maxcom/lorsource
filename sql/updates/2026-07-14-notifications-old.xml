<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-2.0.xsd">

  <changeSet id="2026071401" author="Maxim Valyanskiy">
    <comment>Split oldTracker setting: enable oldNotifications for users who had oldTracker enabled</comment>
    <sql><![CDATA[
      UPDATE user_settings
      SET settings = settings || hstore('oldNotifications', 'true')
      WHERE settings -> 'oldTracker' = 'true';
    ]]></sql>
  </changeSet>

</databaseChangeLog>